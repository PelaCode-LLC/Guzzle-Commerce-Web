{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "guzzle-commerce-web",
  "compatibility_date": "2026-03-24",
  // Runtime Worker vars (for code-based Worker configs).
  // Note: static asset projects do not read these at React build time.
  "vars": {
    "REACT_APP_ENV": "production",
    "REACT_APP_MARKETPLACE_NAME": "Guzzle Commerce",
    "REACT_APP_USE_SHARETRIBE_CONSOLE": "false"
  },
  "assets": {
    "directory": "./build"
  }
}
