# Build-time variables for production bundle.
# These are public in the built JS bundle because they use REACT_APP_ prefix.

REACT_APP_ENV=production
REACT_APP_USE_SHARETRIBE_CONSOLE=false

# Set this to your Render backend URL.
REACT_APP_CUSTOM_BACKEND_URL=https://guzzle-commerce-web.onrender.com

# Set this to your live web domain (no trailing slash).
REACT_APP_MARKETPLACE_ROOT_URL=https://guzzle-web.com
