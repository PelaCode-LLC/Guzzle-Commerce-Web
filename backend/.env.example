# Database (preferred for managed DB)
DATABASE_URL=postgresql://user:password@host:5432/marketplace

# Optional database parts (used if DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=marketplace
DB_USER=postgres
DB_PASSWORD=postgres

# SSL for managed PostgreSQL in production
# Set to "disable" only if your provider does not require SSL
DATABASE_SSL_MODE=require
DB_SSL_REJECT_UNAUTHORIZED=false

# Server
PORT=5000
NODE_ENV=development
JWT_SECRET=your-secret-key-change-in-production

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# File storage – Cloudflare R2 (S3-compatible)
# Leave all R2_* vars unset to fall back to local disk (development only).
# In production all five vars must be set or uploads will be lost on redeploy.
#
# How to get these values:
#   1. Cloudflare Dashboard → R2 → Create bucket → copy bucket name
#   2. R2 → Manage R2 API Tokens → Create token (Object Read & Write)
#      → copy Account ID, Access Key ID, Secret Access Key
#   3. R2 → bucket → Settings → Public access → Enable → copy Public URL
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=guzzle-commerce
# Public URL for the bucket (r2.dev subdomain or custom domain):
R2_PUBLIC_URL=https://pub-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX.r2.dev

# CORS
FRONTEND_URL=http://localhost:3000
# Additional comma-separated frontend origins (e.g. https://app.example.com,https://www.example.com)
FRONTEND_URLS=
