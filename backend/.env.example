# Database (preferred for managed DB)
DATABASE_URL=postgresql://user:password@host:5432/marketplace

# Optional database parts (used if DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=marketplace
DB_USER=postgres
DB_PASSWORD=postgres

# SSL for managed PostgreSQL in production
# Set to "disable" only if your provider does not require SSL
DATABASE_SSL_MODE=require
DB_SSL_REJECT_UNAUTHORIZED=false

# Server
PORT=5000
NODE_ENV=development
JWT_SECRET=your-secret-key-change-in-production

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# File storage (local or S3)
FILE_UPLOAD_PATH=./uploads

# CORS
FRONTEND_URL=http://localhost:3000
# Additional comma-separated frontend origins (e.g. https://app.example.com,https://www.example.com)
FRONTEND_URLS=
